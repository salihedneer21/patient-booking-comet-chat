# Convex Deploy Key (for non-interactive CLI operations)
# Get from: dashboard.convex.dev → Your Project → Settings → Deploy Key
CONVEX_DEPLOY_KEY=prod:your-project-123|eyJ2...

# Convex Deployment URL (for React client)
# Get from: dashboard.convex.dev → Your Project → Settings → Deployment URL
VITE_CONVEX_URL=https://your-project-123.convex.cloud

# HIPAA Banner (shows by default, set to 'true' to hide)
# Automatically set by Specode: hidden in preview, shown in production
VITE_HIDE_HIPAA_BANNER=false

# CometChat Configuration
# Get from: https://app.cometchat.com → Your App → Credentials
VITE_COMETCHAT_APP_ID=your_app_id
VITE_COMETCHAT_REGION=us

# Server-side CometChat credentials (Convex env)
# Set with:
#   npx convex env set COMETCHAT_APP_ID "your_app_id"
#   npx convex env set COMETCHAT_API_KEY "your_api_key"
#   npx convex env set COMETCHAT_REGION "us"
COMETCHAT_APP_ID=your_app_id
COMETCHAT_API_KEY=your_api_key
COMETCHAT_REGION=us
